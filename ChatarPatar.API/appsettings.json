{
    "ConnectionStrings": {
        "AppDbConnection": "connection string for your DB"
    },
    "AppSettings": {
        "ApplicationName": "ChatarPatar",
        "AllowedOrigins": [ "https://localhost:7232", "http://localhost:5184", "http://localhost:3000" ]
    },
    "TokenSettings": {
        "SecretKey": "secret key for JWT access token",
        "Issuer": "https://localhost:7232", //Authentication Server Domain URL
        "Audience": [ "https://localhost:7232", "http://localhost:5184", "http://localhost:3000" ], //Client Application Domain URL
        "TokenExpirationMinutes": 30,
        "RefreshTokenExpirationDays": 6,
        "OtpExpirationMinutes": 10,
        "OtpResendCooldownSeconds": 60,
        "MaxSessions": 5
    },
    "InviteTokenSettings": {
        "ExpirationDays": 7
    },
    "CloudinarySettings": {
        "CloudName": "cloud name",
        "ApiKey": "api key",
        "ApiSecret": "api secret"
    },
    "EmailSettings": {
        "Host": "smtp.gmail.com",
        "Port": 587,
        "From": "Your email address",
        "Username": "Your email address",
        "Password": "your email passkey",
        "EnableSsl": true,
        "DisplayName": "Chatar-Patar",
        "SendToActualRecipients": true,
        "OverrideEmail": "",
        "SubjectPrefix": ""
    },
    "OutboxRetrySettings": {
        "RetryCount": 5,
        "RetryDelayMinutes": 60
    },
    "Serilog": {
        "LevelSwitches": {
            "$systemLogSwitch": "Information"
        },
        "MinimumLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*"
}
